TELEGRAM_BOT_TOKEN=your-token-here
TELEGRAM_ALLOWED_USER_IDS=[...your user ids...]
OPENAI_API_KEY=sk-your-openai-api-key
# Optional: LLM model for the chat agent (default gpt-5-mini)
# OPENAI_CHAT_MODEL=gpt-5-mini
# Optional: whisper-1, gpt-4o-transcribe, …
# OPENAI_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe
# Optional context for STT (German real-estate terms, names)
# OPENAI_TRANSCRIPTION_PROMPT=
# TTS voice for Dobby replies (alloy, ash, ballad, coral, echo, fable, …)
# OPENAI_TTS_VOICE=fable
# OPENAI_TTS_MODEL=gpt-4o-mini-tts
# Playback speed 0.25–4.0 (default 1.2)
# OPENAI_TTS_SPEED=1.2
